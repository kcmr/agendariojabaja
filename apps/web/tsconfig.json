{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "@repo/components/ui/*.vue": ["../../packages/components/src/components/ui/*.vue"],
      "@repo/components/features/*.vue": ["../../packages/components/src/components/features/*.vue"],
      "@repo/components/layout/*.vue": ["../../packages/components/src/components/layout/*.vue"],
      "@repo/components/utils/*.vue": ["../../packages/components/src/components/utils/*.vue"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
