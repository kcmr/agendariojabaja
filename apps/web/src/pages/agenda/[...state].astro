---
import EventList from '../../components/EventList.vue';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getAgendaLocalities,
  getAgendaPageDescription,
  getAgendaPageTitle,
  getAgendaPathParam,
  getAgendaStaticStates,
  getAgendaUrl,
  type AgendaState,
} from '../../lib/agenda';
import { getUpcomingEvents, type WebEvent } from '../../lib/events';

export async function getStaticPaths() {
  const events = await getUpcomingEvents();

  return getAgendaStaticStates(events)
    .filter(
      (state) =>
        !(
          state.locality === 'all' &&
          state.page === 1
        )
    )
    .map((state) => ({
      params: { state: getAgendaPathParam(state) },
      props: { events, state },
    }));
}

interface Props {
  events: WebEvent[];
  state: AgendaState;
}

const { events, state } = Astro.props;
const localities = getAgendaLocalities();
const title = getAgendaPageTitle(state, localities);
const description = getAgendaPageDescription(state, localities);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={getAgendaUrl(state)}
>
  <EventList
    client:load
    events={events}
    state={state}
  />
</BaseLayout>
