---
import Button from '@repo/ui/button';
import Card from '@repo/ui/card';
import Badge from '@repo/ui/badge';
import people from '../data/person.json';
import BaseLayout from '../layouts/BaseLayout.astro';

const res = await fetch('https://jsonplaceholder.typicode.com/todos/1');
const data = await res.json();
---

<BaseLayout title='Home'>
  <Button>Click me</Button>
  <Card
    heading='Card Title'
    text='This is a card description.'
    image={{
      src: '//wsrv.nl/?url=wsrv.nl/lichtenstein.jpg&w=300',
      alt: 'Card image',
    }}
  >
    <Badge slot='tag' variant='brand' shape='square'
      ><time datetime='2026-05-25'>2026-05-25</time></Badge
    >
  </Card>

  <div slot='experiments'>
    <p>Estás en al página <strong>Home</strong></p>
    <p class='text-2xl'>Todo: {data.title}</p>

    <ul class='list-inside list-disc'>
      {
        people.map((person) => (
          <li>
            {person.name} - {person.age} years old - {person.email}
            <ul class='list-inside list-disc ml-3'>
              {person.hobbies.map((hobby) => (
                <li>{hobby}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
