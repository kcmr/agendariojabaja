---
import EventList from '../components/EventList.vue';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  DEFAULT_AGENDA_LOCALITY,
  DEFAULT_AGENDA_PAGE,
  getAgendaLocalities,
  getAgendaPageDescription,
  getAgendaPageTitle,
  getAgendaUrl,
} from '../lib/agenda';
import { getPublicEvents } from '../lib/events';

const events = await getPublicEvents();
const state = {
  locality: DEFAULT_AGENDA_LOCALITY,
  page: DEFAULT_AGENDA_PAGE,
} as const;
const localities = getAgendaLocalities();
const title = getAgendaPageTitle(state, localities);
const description = getAgendaPageDescription(state, localities);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={getAgendaUrl(state)}
>
  <EventList
    client:load
    events={events}
    state={state}
  />
</BaseLayout>
