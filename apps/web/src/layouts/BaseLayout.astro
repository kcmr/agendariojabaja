---
import AppHeader from '@repo/components/features/AppHeader';
import AppFooter from '@repo/components/features/AppFooter';
import NewsletterSignup from '@repo/components/features/NewsletterSignup';
import { ClientRouter } from 'astro:transitions';
import {
  DEFAULT_AGENDA_PAGE,
  getAgendaLocalities,
  getAgendaUrl,
} from '../lib/agenda';
import { getPublicEnv } from '../lib/env';
import '../styles/global.css';

interface Props {
  title?: string;
  showNewsletterSignup?: boolean;
  localityLinks?: Array<{
    label: string;
    href: string;
  }>;
}

const title = Astro.props.title ?? 'Agenda Rioja Baja';
const showNewsletterSignup = Astro.props.showNewsletterSignup ?? true;
const localities = Astro.props.localityLinks ? [] : getAgendaLocalities();
const localityLinks =
  Astro.props.localityLinks ??
  localities.map((locality) => ({
    label: `Eventos en ${locality.label}`,
    href: getAgendaUrl({
      locality: locality.id,
      page: DEFAULT_AGENDA_PAGE,
    }),
  }));
const { kitFormActionUrl } = getPublicEnv();
---

<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <title>{title}</title>
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <ClientRouter />
  </head>
  <body class='bg-surface-body flex min-h-dvh flex-col'>
    <a class='skip-link' href='#main'>Saltar al contenido</a>
    <div transition:persist='site-header'>
      <AppHeader
        brand={{
          label: 'Agenda Rioja Baja',
          headline: 'Eventos y ocio local',
          href: '/',
          logoSrc: '/images/arb-instagram-profile.webp',
        }}
        links={[
          {
            label: 'Suscríbete',
            href: '/suscribete',
            icon: 'Mail',
            variant: 'text',
          },
          { label: 'Enviar evento', href: '/enviar-evento', variant: 'brand' },
        ]}
      />
    </div>

    <main id='main' class='flex-1 p-4' tabindex='-1'>
      <div class='mx-auto max-w-7xl p-4 sm:px-6 lg:px-8'>
        <slot />
      </div>
    </main>
    {showNewsletterSignup && <NewsletterSignup action={kitFormActionUrl} />}
    <AppFooter
      linksHeading='Explora planes por localidad'
      links={localityLinks}
    />
    <script>
      import '../scripts/back-navigation';
    </script>
  </body>
</html>
