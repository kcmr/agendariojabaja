    <meta charset='UTF-8' />
    <title>Tutorial – {Astro.props.title}</title>
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  </head>
  <body>
    <nav>
      <ul class='flex gap-3 p-4 border-b border-blue-700 mb-4'>
        <li><Link href='/'>Home</Link></li>
        <li><Link href='/about'>About</Link></li>
      </ul>
    </nav>
    <main class='p-4'>
      <slot />
      <div class='border-dotted border-2 border-amber-500 p-4 mt-4'>
        <slot name='experiments' />
      </div>
    </main>
  </body>
</html>
