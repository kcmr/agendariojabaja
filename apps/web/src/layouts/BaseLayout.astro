---
import AppHeader from '@repo/components/features/AppHeader';
import AppFooter from '@repo/components/features/AppFooter';
import NewsletterSignup from '@repo/components/features/NewsletterSignup';
import { ClientRouter } from 'astro:transitions';
import {
  DEFAULT_AGENDA_PAGE,
  getAgendaLocalities,
  getAgendaUrl,
} from '../lib/agenda';
import { getPublicEnv } from '../lib/env';
import { isProductionMode } from '../lib/runtime';
import { SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  pageType?: 'website' | 'article';
  noindex?: boolean;
  showNewsletterSignup?: boolean;
  localityLinks?: Array<{
    label: string;
    href: string;
  }>;
}

const publicEnv = getPublicEnv();
const siteUrl = publicEnv.siteUrl ?? SITE.fallbackUrl;
const title = Astro.props.title ?? SITE.name;
const description = Astro.props.description ?? SITE.defaultDescription;
const pageType = Astro.props.pageType ?? 'website';
const image = Astro.props.image ?? SITE.defaultImage;
const showNewsletterSignup = Astro.props.showNewsletterSignup ?? true;
const localities = Astro.props.localityLinks ? [] : getAgendaLocalities();
const localityLinks =
  Astro.props.localityLinks ??
  localities.map((locality) => ({
    label: `Eventos en ${locality.label}`,
    href: getAgendaUrl({
      locality: locality.id,
      page: DEFAULT_AGENDA_PAGE,
    }),
  }));
const { kitFormActionUrl, umamiScriptUrl, umamiWebsiteId } = publicEnv;
const hasAnalytics = Boolean(
  umamiScriptUrl && umamiWebsiteId && isProductionMode,
);

const toAbsoluteUrl = (pathOrUrl: string) => {
  try {
    return new URL(pathOrUrl).toString();
  } catch {
    return new URL(pathOrUrl, siteUrl).toString();
  }
};

const canonicalUrl = toAbsoluteUrl(
  Astro.props.canonicalPath ?? Astro.url.pathname,
);
const imageUrl = toAbsoluteUrl(image);
---

<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='icon' href='/favicon.ico' sizes='any' />
    <link
      rel='icon'
      type='image/png'
      sizes='32x32'
      href='/icons/favicon-32x32.png'
    />
    <link
      rel='icon'
      type='image/png'
      sizes='16x16'
      href='/icons/favicon-16x16.png'
    />
    <link rel='apple-touch-icon' href='/apple-touch-icon.png' />
    <link rel='manifest' href='/site.webmanifest' />
    <link rel='sitemap' href='/sitemap-index.xml' />
    {Astro.props.noindex && <meta name='robots' content='noindex, follow' />}
    <link rel='canonical' href={canonicalUrl} />
    <meta property='og:site_name' content={SITE.name} />
    <meta property='og:locale' content={SITE.locale} />
    <meta property='og:type' content={pageType} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:image' content={imageUrl} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={imageUrl} />
    {
      hasAnalytics && (
        <script
          is:inline
          defer
          src={umamiScriptUrl}
          data-website-id={umamiWebsiteId}
        />
      )
    }
    <ClientRouter />
  </head>
  <body class='bg-surface-body flex min-h-dvh flex-col'>
    <a class='skip-link' href='#main'>Saltar al contenido</a>
    <div transition:persist='site-header'>
      <AppHeader
        brand={{
          label: 'Agenda Rioja Baja',
          headline: 'Eventos y ocio local',
          href: '/',
          logoSrc: '/images/arb-instagram-profile.webp',
        }}
        links={[
          {
            label: 'Suscríbete',
            href: '/suscribete',
            icon: 'Mail',
            variant: 'text',
            analyticsEvent: 'newsletter_header_click',
            analyticsLocation: 'header',
          },
          {
            label: 'Enviar evento',
            href: '/enviar-evento',
            variant: 'brand',
            analyticsEvent: 'submit_event_header_click',
            analyticsLocation: 'header',
          },
        ]}
      />
    </div>

    <main id='main' class='flex-1 px-4 py-4 sm:px-0' tabindex='-1'>
      <div class='mx-auto max-w-7xl sm:px-6 lg:px-8'>
        <slot />
      </div>
    </main>
    {
      showNewsletterSignup && (
        <NewsletterSignup
          action={kitFormActionUrl}
          analyticsLocation='footer'
        />
      )
    }
    <AppFooter
      linksHeading='Explora planes por localidad'
      links={localityLinks}
    />
    <script>
      import '../scripts/back-navigation';
      import '../scripts/analytics';
    </script>
  </body>
</html>
