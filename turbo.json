{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".astro/**"],
      "env": [
        "ASTRO_ADAPTER",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_ANON_KEY",
        "N8N_WEBHOOK_URL",
        "N8N_FORM_SECRET",
        "TURNSTILE_SECRET_KEY",
        "PUBLIC_*"
      ]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.js", ".eslintrc*"]
    },
    "format": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", ".prettierrc*", "prettier.config.js"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview:local": {
      "cache": false,
      "persistent": true
    }
  }
}
